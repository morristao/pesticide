PORT=8000
FRONTEND_ORIGIN=https://your-frontend.example.com
# Optional: override model location (defaults to backend/model_store/leaf9)
# LEAF9_DIR=C:\\path\\to\\Leaf_9_model
# Optional overrides (usually not needed):
# LEAF9_CKPT=best.ckpt
# LEAF9_LABEL_MAP=C:\\path\\to\\Leaf_9_model\\data\\label_map.json
# LEAF9_BACKBONE=auto  # or efficientnet_v2_s / resnet50
# LEAF9_DEVICE=cpu     # auto-selects cuda if available
# LEAF9_IMG_SIZE=448

# OvA ensemble (one-vs-all) mode
# LEAF9_MODE=ova  # set to 'ova' to use per-class best-fold checkpoints
# LEAF9_OVA_DIR=backend/model_store/leaf9/ova
# LEAF9_OVA_MAP=backend/model_store/leaf9/ova/ova_map.json
